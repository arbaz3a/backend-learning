<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="bg-zinc-900 min-h-screen text-white p-6">
        <p class="mb-4 text-zinc-300">Update your post</p>
        <form method="post" action="/update/<%= post._id %>" class="flex flex-col gap-3 w-full md:w-1/3">
            <textarea class="resize-none bg-zinc-800 p-3 rounded-md outline-none focus:ring-2 focus:ring-red-500"
                rows="4" placeholder="Share your thoughts..." name="content"><%= post.content %></textarea>
            <input type="submit" value="Update"
                class="bg-yellow-400 text-black py-2 w-20 rounded-md cursor-pointer hover:bg-yellow-500 transition" />
        </form>
    </div>
</body>

</html>