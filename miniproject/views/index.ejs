<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create User</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="bg-zinc-800 w-full h-screen p-7 text-white">
      <h1 class="text-xl mb-3">Create Account</h1>

      <form action="/register" method="POST">
        <input
          type="text"
          name="name"
          placeholder="name"
          class="p-1 border rounded-lg focus:outline-none"
        />
        <input
          type="text"
          name="username"
          placeholder="Username"
          class="p-1 border rounded-lg focus:outline-none"
        />

        <input
          type="email"
          name="email"
          placeholder="Email"
          class="p-1 border rounded-lg focus:outline-none"
        />

        <input
          type="password"
          name="password"
          placeholder="Password"
          class="p-1 border rounded-lg focus:outline-none"
        />

        <input
          type="number"
          name="age"
          placeholder="Age"
          class="p-1 border rounded-lg focus:outline-none"
        />

        <button
          type="submit"
          class="bg-blue-500 text-white p-1 rounded-lg"
        >
          Create User
        </button>
      </form>
    </div>
  </body>
</html>
