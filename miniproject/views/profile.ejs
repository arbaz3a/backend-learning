<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="bg-zinc-900 min-h-screen text-white p-6">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-semibold">
                Hello <span class="text-red-400">
                    <%= user.name %>
                </span>
            </h1>
            <a href="/logout"
                class="bg-red-600 px-4 py-1.5 text-black text-bold rounded-md hover:bg-red-700 transition">
                Logout
            </a>
        </div>
        <div class="mb-8">
            <p class="mb-2 text-zinc-300">Create a post</p>
            <form method="post" action="/post" class="flex flex-col gap-2 w-full md:w-1/3">
                <textarea class="resize-none bg-zinc-800 p-3 rounded-md outline-none focus:ring-2 focus:ring-red-500"
                    rows="4" placeholder="Share your thoughts..." name="content"></textarea>
                <input type="submit" value="Create Post"
                    class="bg-red-600 text-black py-2 rounded-md cursor-pointer hover:bg-red-700 transition" />
            </form>
        </div>
        <div>
            <h2 class="text-xl mb-4">Your Posts</h2>
            <div class="flex flex-wrap gap-3">
                <% user.posts.reverse().forEach((post)=>{ %>
                    <div class="w-full md:w-[32%] bg-zinc-800 p-3 rounded-lg shadow">
                        <h3 class="font-semibold mb-2 text-blue-500">
                            <%= user.name %>
                        </h3>
                        <p class="text-zinc-300 mb-3">
                            <%= post.content %>
                        </p>
                        <div class="flex gap-4 text-sm">
                            <a href="#" class="text-blue-400 hover:underline">Like</a>
                            <a href="#" class="text-zinc-400 hover:underline">Edit</a>
                        </div>
                    </div>
                <% }) %>
        </div>
    </div>
    </div>
</body>

</html>